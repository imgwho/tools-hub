---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import * as LucideIcons from "lucide-astro";
import { ArrowLeft, Play } from 'lucide-astro';

export async function getStaticPaths() {
  const tools = await getCollection('tools');
  return tools.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, icon, url, type } = entry.data;

const IconComponent = LucideIcons[icon as keyof typeof LucideIcons] || LucideIcons.AppWindow;
---

<BaseLayout title={`${title} | 华子的快捷工具箱`}>
  <header class="h-16 border-b border-zinc-100 flex items-center sticky top-0 bg-white/80 backdrop-blur-md z-50">
    <div class="container mx-auto px-6 flex items-center gap-4">
      <a href="/" class="p-2 hover:bg-zinc-100 rounded-lg transition-colors text-zinc-400 hover:text-zinc-900">
        <ArrowLeft size={18} />
      </a>
      <span class="text-zinc-300">/</span>
      <span class="font-bold text-sm tracking-tight text-zinc-900">{title}</span>
    </div>
  </header>

  <main class="container mx-auto px-6 py-12 max-w-4xl">
    <div class="flex items-center gap-6 mb-12 pb-12 border-b border-zinc-100">
      <div class="bg-zinc-900 text-white w-20 h-20 rounded-2xl flex items-center justify-center shadow-lg shadow-zinc-200">
        <IconComponent size={36} strokeWidth={2} />
      </div>
      <div class="flex-grow">
        <h1 class="text-3xl font-black text-zinc-900 tracking-tight mb-2">{title}</h1>
        <p class="text-zinc-500 font-medium leading-relaxed">{description}</p>
      </div>
      <div>
        <a href={url} class="btn btn-primary h-14 px-8 text-white font-bold rounded-2xl flex items-center gap-2" target="_self">
          <Play size={18} fill="currentColor" />
          启动工具
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
      <article class="prose lg:col-span-2">
        <Content />
      </article>
      
      <aside class="space-y-8">
        <div class="bg-zinc-50 rounded-2xl p-6 border border-zinc-100">
          <h4 class="text-xs font-black uppercase tracking-widest text-zinc-400 mb-4">工具元数据</h4>
          <div class="space-y-4">
            <div class="flex items-center justify-between text-sm">
              <span class="text-zinc-400">资源类型</span>
              <strong class="text-zinc-900 font-bold">{type.toUpperCase()}</strong>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-zinc-400">运行环境</span>
              <strong class="text-zinc-900 font-bold">本地浏览器</strong>
            </div>
            <div class="flex items-center justify-between text-sm">
              <span class="text-zinc-400">版本状态</span>
              <strong class="text-emerald-600 font-bold bg-emerald-50 px-2 py-0.5 rounded text-[10px] uppercase">Stable</strong>
            </div>
          </div>
        </div>
        
        <div class="bg-zinc-900 rounded-2xl p-6 text-white shadow-xl shadow-zinc-200">
          <h4 class="text-xs font-bold uppercase tracking-widest text-zinc-500 mb-4">安全提示</h4>
          <p class="text-xs leading-relaxed text-zinc-400">此工具完全在本地运行，你的数据不会上传到任何服务器。确保浏览器版本处于最新状态。</p>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
